{
  "gallery": {
    "title": "Expediciones Montañísticas",
    "subtitle": "Momentos capturados en las cumbres más desafiantes de la cordillera chilena e internacional",
    "basePath": "media/images/fundador/gallery/",
    "supportedFormats": ["jpg"],
    "photoFilePattern": "_\\d{4}\\.jpg$",
    "coverFilePattern": "_cover\\.jpg$"
  },
  
  "detection": {
    "enabled": false,
    "maxPhotos": 15,
    "maxGaps": 2,
    "timeout": 1000,
    "mode": "predefined"
  },
  
  "ui": {
    "newBadgeDuration": 21,
    "newBadgeText": "NUEVO",
    "photoCounterFormat": "{current} / {total}",
    "loadingText": "Cargando...",
    "errorText": "Error al cargar",
    "noPhotosText": "Sin fotos disponibles"
  },
  
  "filters": {
    "showAll": true,
    "defaultFilter": "todos",
    "buttons": [
      {
        "id": "todos", 
        "label": "Todos",
        "category": null
      },
      {
        "id": "cerros",
        "label": "Cerros", 
        "category": "cerros"
      },
      {
        "id": "volcanes",
        "label": "Volcanes",
        "category": "volcanes"
      },
      {
        "id": "sierras", 
        "label": "Sierras",
        "category": "sierras"
      }
    ]
  },

  "sorting": {
    "defaultSort": "featured",
    "options": [
      {
        "id": "featured",
        "label": "Destacados",
        "field": "featured",
        "direction": "desc"
      },
      {
        "id": "altitude", 
        "label": "Altitud",
        "field": "altitude",
        "direction": "desc"
      },
      {
        "id": "name",
        "label": "Nombre",
        "field": "name", 
        "direction": "asc"
      },
      {
        "id": "difficulty",
        "label": "Dificultad",
        "field": "difficulty.grade",
        "direction": "asc"
      },
      {
        "id": "ascents",
        "label": "Ascensos", 
        "field": "ascents",
        "direction": "desc"
      }
    ]
  },

  "layout": {
    "cardsPerRow": {
      "desktop": 3,
      "tablet": 2, 
      "mobile": 1
    },
    "cardMinWidth": "350px",
    "cardAspectRatio": "4:5",
    "overlayLayout": {
      "infoPanel": "33.333%",
      "photosPanel": "66.667%"
    }
  },

  "animations": {
    "cardHover": {
      "enabled": true,
      "transformY": "-8px",
      "duration": "0.3s"
    },
    "overlayTransition": {
      "enabled": true,
      "duration": "0.4s",
      "easing": "ease-in-out"
    },
    "photoTransition": {
      "enabled": true,
      "duration": "0.3s", 
      "easing": "ease"
    }
  },

  "mobile": {
    "swipeThreshold": 50,
    "doubleTapZoom": false,
    "uiHideDelay": 3000,
    "gestures": {
      "swipeLeft": "nextPhoto",
      "swipeRight": "prevPhoto", 
      "swipeUp": "closeGallery",
      "swipeDown": "showInfo",
      "singleTap": "toggleUI",
      "doubleTap": "disabled"
    }
  },

  "performance": {
    "lazyLoading": true,
    "preloadNext": 1,
    "thumbnailQuality": 70,
    "maxPhotoSize": "1200x900",
    "cacheDuration": 3600000,
    "enableOptimizations": true
  },

  "accessibility": {
    "altTextPattern": "{expedition} - Foto {number}",
    "keyboardNavigation": true,
    "screenReaderSupport": true,
    "highContrastMode": false
  },

  "debug": {
    "enabled": true,
    "logLevel": "info",
    "showLoadTimes": true,
    "photoDetectionLog": true
  }
}